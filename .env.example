# Copy this file to .env.local and fill in your own Supabase project's values.
# Find both under Project Settings -> API in the Supabase dashboard.
# These are safe to expose in a client app (the anon key only works within
# the Row Level Security rules you set up in supabase_schema.sql).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
